# =============================================================
# SwarmForge Production Environment
# Copy to .env.production and fill in all values
# NEVER commit .env.production to version control
# =============================================================

# ---- Domain ----
DOMAIN=yourdomain.com

# ---- PostgreSQL ----
POSTGRES_USER=swarmforge
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=swarmforge

# ---- GitHub ----
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=CHANGE_ME_RANDOM_32_CHARS

# ---- GitLab (optional) ----
GITLAB_TOKEN=glpat-your_token_here
GITLAB_WEBHOOK_SECRET=CHANGE_ME_RANDOM_32_CHARS
GITLAB_BASE_URL=https://gitlab.com

# ---- LiteLLM ----
LITELLM_MASTER_KEY=sk-CHANGE_ME_RANDOM_32_CHARS
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_key_here

# ---- Backend ----
DEBUG=false
DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# ---- CORS (comma-separated, use your actual domain) ----
CORS_ORIGINS=https://yourdomain.com
