{
  "name": "swarmforge-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/server.ts",
    "dev:client": "vite --port 5173",
    "build": "vite build",
    "start": "tsx server/server.ts",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && node scripts/electron-build.cjs"
  },
  "dependencies": {
    "express": "^4.21.2",
    "ws": "^8.18.0",
    "better-sqlite3": "^11.7.0",
    "@octokit/rest": "^21.1.1",
    "claude-code-sdk": "^0.1.0",
    "which": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-use-websocket": "^4.11.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.12",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.0.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "typescript": "^5.5.0",
    "tsx": "^4.19.0",
    "concurrently": "^9.1.0",
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/uuid": "^10.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/which": "^3.0.0"
  }
}
