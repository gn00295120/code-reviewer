# Database
DATABASE_URL=postgresql+asyncpg://swarmforge:swarmforge@localhost:5432/swarmforge
DATABASE_URL_SYNC=postgresql://swarmforge:swarmforge@localhost:5432/swarmforge
POSTGRES_USER=swarmforge
POSTGRES_PASSWORD=swarmforge
POSTGRES_DB=swarmforge

# Redis
REDIS_URL=redis://localhost:6379/0

# GitHub
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# GitLab
GITLAB_TOKEN=glpat-your_token_here
GITLAB_WEBHOOK_SECRET=your_gitlab_webhook_secret
GITLAB_BASE_URL=https://gitlab.com

# LiteLLM
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-litellm-master-key

# Default LLM
DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
